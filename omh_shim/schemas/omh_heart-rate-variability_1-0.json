{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "description": "Non-standard heart-rate-variability schema. Open mHealth has not published a canonical HRV schema as of 2026-04. This placeholder mirrors the OMH unit-value/time-frame patterns so converters can target it consistently. Re-vendor with the canonical schema if/when one is published upstream.",
    "type": "object",
    "definitions": {
        "unit_value": {
            "type": "object",
            "properties": {
                "value": {"type": "number"},
                "unit": {"type": "string"}
            },
            "required": ["value", "unit"]
        },
        "date_time": {
            "type": "string",
            "format": "date-time"
        }
    },
    "properties": {
        "heart_rate_variability": {
            "allOf": [
                {"$ref": "#/definitions/unit_value"},
                {"properties": {"unit": {"enum": ["ms"]}}}
            ]
        },
        "effective_time_frame": {
            "type": "object",
            "properties": {
                "date_time": {"$ref": "#/definitions/date_time"}
            },
            "required": ["date_time"]
        }
    },
    "required": ["heart_rate_variability", "effective_time_frame"]
}
